# Caddy config for the Community Resource Directory.
# Caddy automatically obtains and renews Let's Encrypt certificates for the
# domain(s) below and terminates TLS, proxying to the app over plain HTTP
# on the internal network. No cron, no certbot, no manual renewal.
#
# {$SITE_ADDRESS} and {$UPSTREAM} are filled from environment variables
# (see .env / docker-compose.tls.yml). SITE_ADDRESS should be your domain,
# e.g. help.example.org. Use :80 instead of a domain to test without TLS.

{$SITE_ADDRESS} {
	encode zstd gzip
	reverse_proxy {$UPSTREAM:directory:8080}

	# Privacy: do not write access logs. For a directory used by people at risk,
	# a log of who looked up what — with IPs and timestamps — is itself a hazard.
	# Caddy logs to stdout by default; this turns it off. (Errors still surface.)
	log {
		output discard
	}

	# Security / privacy headers.
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		# Send no referrer at all, so outbound clicks (Directions, org sites)
		# don't leak that the user came from this directory.
		Referrer-Policy no-referrer
		-Server
		# HSTS is commented out by default: only enable once you're certain the
		# domain will always be HTTPS (it's hard to undo).
		# Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}
}
