# Copy to .env in the repo root and fill in. Used by docker compose.
#   cp deploy/env.example .env

# Your domain. DNS A/AAAA record must already point at this server's IP.
SITE_ADDRESS=help.example.org

# Enable the /admin editor. Leave blank to run read-only.
ADMIN_PASSWORD=

# Optional: persist admin login tokens across restarts (any long random string).
ADMIN_TOKEN_SECRET=
